<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="QuestResume.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:QuestResume.Mobile.Pages"
    Title="QuestResume"
    FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent Title="Busca" Route="search" ContentTemplate="{DataTemplate pages:SearchPage}" />
        <ShellContent Title="Perguntar" Route="ask" ContentTemplate="{DataTemplate pages:AskPage}" />
        <ShellContent Title="Configurações" Route="settings" ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </TabBar>

</Shell>
