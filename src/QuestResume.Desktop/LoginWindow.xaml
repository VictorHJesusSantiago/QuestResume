<Window x:Class="QuestResume.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuestResume - Login" Height="260" Width="360"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Entrar no QuestResume" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Text="Usuário" Margin="0,0,0,3"/>
        <TextBox x:Name="UsernameBox" Grid.Row="1" Margin="0,20,0,10" Padding="5"/>

        <TextBlock Grid.Row="2" Text="Senha" Margin="0,0,0,3"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="2" Margin="0,20,0,10" Padding="5"/>

        <TextBlock x:Name="ErrorText" Grid.Row="3" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn_Entrar}" Click="OnLoginClick" Padding="15,5" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
