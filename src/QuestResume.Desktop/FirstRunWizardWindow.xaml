<Window x:Class="QuestResume.Desktop.FirstRunWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bem-vindo ao QuestResume" Height="330" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Grid.Row="0" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"
                   Text="Passo 1 de 3 — Pasta de documentos"/>

        <Grid Grid.Row="1">
            <!-- Passo 1: pasta de documentos -->
            <StackPanel x:Name="Step1Panel">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                           Text="Selecione a pasta onde estão os documentos (PDF, DOCX, TXT, etc.) que você quer poder pesquisar e perguntar."/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DocumentsFolderBox" Grid.Column="0" Padding="5" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Content="Procurar..." Padding="10,4" Click="OnBrowseDocumentsFolder"/>
                </Grid>
            </StackPanel>

            <!-- Passo 2: caminho do modelo -->
            <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                           Text="Selecione o modelo de linguagem local (.gguf) que será usado para responder às suas perguntas. Você pode baixar um modelo compatível com LLamaSharp e configurar este caminho depois, se preferir."/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ModelPathBox" Grid.Column="0" Padding="5" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Content="Procurar..." Padding="10,4" Click="OnBrowseModel"/>
                </Grid>
            </StackPanel>

            <!-- Passo 3: primeira indexação -->
            <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                           Text="Tudo pronto! Ao concluir, suas configurações serão salvas. Você pode indexar a pasta de documentos agora, ou fazer isso depois na aba Perguntas."/>
                <CheckBox x:Name="IndexNowCheckBox" Content="Indexar a pasta de documentos agora" IsChecked="True"/>
                <TextBlock x:Name="Step3Status" Margin="0,10,0,0" Foreground="Gray" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BackButton" Content="Voltar" Padding="15,5" Margin="0,0,10,0" Click="OnBackClick" IsEnabled="False"/>
            <Button x:Name="NextButton" Content="Próximo" Padding="15,5" IsDefault="True" Click="OnNextClick"/>
        </StackPanel>
    </Grid>
</Window>
