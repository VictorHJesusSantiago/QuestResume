<Window x:Class="QuestResume.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuestResume.Desktop"
        xmlns:converters="clr-namespace:QuestResume.Desktop.Converters"
        xmlns:behaviors="clr-namespace:QuestResume.Desktop.Behaviors"
        mc:Ignorable="d"
        Title="QuestResume" Height="650" Width="900"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">
    <Window.InputBindings>
        <!-- Atalhos de teclado: Ctrl+Enter envia a pergunta, Ctrl+K foca a caixa de pergunta,
             Ctrl+I inicia a indexação. Mantidos consistentes com os atalhos padrão do Web UI. -->
        <KeyBinding Key="Return" Modifiers="Ctrl" Command="{Binding AskCommand}"/>
        <KeyBinding Key="K" Modifiers="Ctrl" Command="{Binding FocusQuestionCommand}"/>
        <KeyBinding Key="I" Modifiers="Ctrl" Command="{Binding IndexCommand}"/>
    </Window.InputBindings>
    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <DockPanel>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10,10,10,0" HorizontalAlignment="Left">
        <TextBlock Text="Coleção:" VerticalAlignment="Center" Margin="0,0,5,0"/>
        <ComboBox Width="160" ItemsSource="{Binding AvailableCollections}"
                  SelectedItem="{Binding SelectedCollection, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBox x:Name="NewCollectionNameBox" Width="120" Padding="4" Margin="10,0,0,0"
                 VerticalContentAlignment="Center" ToolTip="Nome da nova coleção"/>
        <Button Content="Criar coleção" Padding="8,4" Margin="5,0,0,0"
                Command="{Binding CreateCollectionCommand}" CommandParameter="{Binding Text, ElementName=NewCollectionNameBox}"/>
    </StackPanel>
    <TabControl Margin="10">
        <TabItem Header="{DynamicResource Tab_Perguntas}">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Text="{Binding DocumentsFolder, UpdateSourceTrigger=PropertyChanged}"
                             Width="500" Padding="5" VerticalContentAlignment="Center" Margin="0,0,5,0"/>
                    <Button Content="{DynamicResource Btn_Procurar}" Command="{Binding BrowseFolderCommand}" Padding="10,4" Margin="0,0,5,0"/>
                    <Button Content="{DynamicResource Btn_Indexar}" Command="{Binding IndexCommand}" Padding="10,4"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
                           Margin="0,10,0,0" TextWrapping="Wrap" Foreground="Gray"/>

                <ProgressBar DockPanel.Dock="Bottom" Height="16" Margin="0,6,0,0"
                             Minimum="0" Maximum="{Binding IndexingTotal}" Value="{Binding IndexingCurrent}"
                             Visibility="{Binding IsIndexingProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <TextBlock DockPanel.Dock="Bottom" Margin="0,4,0,0" FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                           Text="Atalhos: Ctrl+Enter envia a pergunta · Ctrl+K foca esta caixa · Ctrl+I indexa a pasta configurada."/>

                <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="QuestionTextBox" Grid.Column="0" Padding="5" VerticalContentAlignment="Center" Margin="0,0,5,0"
                             Text="{Binding QuestionText, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="1" Content="{DynamicResource Btn_Perguntar}" Command="{Binding AskCommand}" Padding="10,4" Margin="0,0,5,0"
                            ToolTip="Ctrl+Enter"/>
                    <Button Grid.Column="2" Content="Exportar conversa" Command="{Binding ExportChatCommand}" Padding="10,4" Margin="0,0,5,0"/>
                    <Button Grid.Column="3" Content="Exportar PDF" Command="{Binding ExportChatPdfCommand}" Padding="10,4"/>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4" Padding="8" CornerRadius="4" Background="#F0F0F0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Role}" FontWeight="Bold" FontSize="11" Foreground="Gray"/>
                                        <TextBlock behaviors:MarkdownTextBehavior.MarkdownText="{Binding Text}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <ComboBox Width="70" Padding="3" FontSize="11"
                                                      ItemsSource="{Binding DataContext.TranslateLanguageOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding DataContext.TranslateTargetLanguage, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Content="Traduzir" Padding="8,3" FontSize="11" Margin="5,0,0,0"
                                                    Command="{Binding DataContext.TranslateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding RelatedQuestions}" Margin="0,4,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding}" Padding="6,2" FontSize="11" Margin="0,0,4,4"
                                                            Command="{Binding DataContext.AskRelatedQuestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                                     Visibility="{Binding Sources, Converter={StaticResource NullToVisibilityConverter}}">
                                            <TextBlock Text="Fontes: " FontStyle="Italic" FontSize="11" Foreground="Gray"/>
                                            <ItemsControl ItemsSource="{Binding Sources}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                                            <Button Content="{Binding DisplayLabel}"
                                                                    ToolTip="Ver o trecho usado nesta resposta"
                                                                    Command="{Binding DataContext.ViewSourceChunkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="0,0,4,0" Padding="0" Cursor="Hand"
                                                                    Background="Transparent" BorderThickness="0">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <TextBlock Text="{TemplateBinding Content}"
                                                                                   TextDecorations="Underline"
                                                                                   Foreground="#0066CC" FontSize="11"/>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                            <Button Content="(abrir arquivo)"
                                                                    ToolTip="{Binding SourcePath}"
                                                                    Command="{Binding DataContext.OpenSourceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding SourcePath}"
                                                                    Padding="0" Cursor="Hand"
                                                                    Background="Transparent" BorderThickness="0">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <TextBlock Text="{TemplateBinding Content}"
                                                                                   TextDecorations="Underline"
                                                                                   Foreground="Gray" FontSize="11"/>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </TabItem>

        <TabItem Header="{DynamicResource Tab_Documentos}">
            <DockPanel Margin="10">
                <Button DockPanel.Dock="Top" Content="Atualizar lista" Command="{Binding LoadDocumentsCommand}"
                        Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0"
                            Visibility="{Binding IndexErrors, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="Erros na última indexação" FontWeight="Bold" Foreground="#CC0000" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding IndexErrors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="11" Foreground="#CC0000" Margin="0,0,0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0"
                            Visibility="{Binding IndexDuplicates, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="Arquivos duplicados (não indexados novamente)" FontWeight="Bold" Foreground="#CC8800" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding IndexDuplicates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#CC8800" Margin="0,0,0,2">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}  (idêntico a {1})">
                                            <Binding Path="Path"/>
                                            <Binding Path="DuplicateOfPath"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding IndexedDocuments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,3" Padding="8" CornerRadius="4" Background="#F0F0F0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FileName}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding SourcePath}" Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
                                            <TextBlock Foreground="Gray" FontSize="11">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} trecho(s)">
                                                        <Binding Path="ChunkCount"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Summary, StringFormat='Resumo: {0}'}" Foreground="Gray" FontSize="11"
                                                       TextWrapping="Wrap" Margin="0,3,0,0"
                                                       Visibility="{Binding Summary, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <Grid Margin="0,5,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Padding="4" FontSize="11" Margin="0,0,5,0"
                                                         Text="{Binding TagsInput, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="Tags separadas por vírgula"/>
                                                <Button Grid.Column="1" Content="Salvar tags" Padding="8,3" FontSize="11"
                                                        Command="{Binding DataContext.SaveTagsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <Button Content="Extrair tabela" Padding="10,4" Margin="0,0,0,5"
                                                    Command="{Binding DataContext.ExtractTableCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding SourcePath}"/>
                                            <Button Content="Remover" Padding="10,4"
                                                    Command="{Binding DataContext.RemoveDocumentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding SourcePath}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </TabItem>

        <TabItem Header="{DynamicResource Tab_Estudo}">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Width="450" Padding="5" Margin="0,0,5,0" VerticalContentAlignment="Center"
                             Text="{Binding StudyDocumentPath, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Caminho do documento indexado (copie da aba Documentos)"/>
                    <TextBox Width="50" Padding="5" Margin="0,0,5,0" VerticalContentAlignment="Center"
                             Text="{Binding StudyCount, UpdateSourceTrigger=PropertyChanged}" ToolTip="Quantidade"/>
                    <Button Content="Gerar flashcards" Command="{Binding GenerateFlashcardsCommand}" Padding="10,4" Margin="0,0,5,0"/>
                    <Button Content="Gerar quiz" Command="{Binding GenerateQuizCommand}" Padding="10,4"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="Gray"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Flashcards" FontWeight="Bold" Margin="0,0,0,5"
                                   Visibility="{Binding Flashcards, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding Flashcards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4" Padding="10" CornerRadius="4" Background="#F0F0F0" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding FlipCommand}"/>
                                        </Border.InputBindings>
                                        <StackPanel>
                                            <TextBlock Text="Pergunta:" FontWeight="Bold" FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Question}" TextWrapping="Wrap" Margin="0,2,0,6"/>
                                            <TextBlock Text="Resposta (clique para revelar):" FontWeight="Bold" FontSize="11" Foreground="Gray"
                                                       Visibility="{Binding IsFlipped, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding Answer}" TextWrapping="Wrap" Margin="0,2,0,0"
                                                       Visibility="{Binding IsFlipped, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Quiz" FontWeight="Bold" Margin="0,15,0,5"
                                   Visibility="{Binding QuizQuestions, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding QuizQuestions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4" Padding="10" CornerRadius="4" Background="#F0F0F0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Question}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <ItemsControl ItemsSource="{Binding IndexedOptions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Text}" HorizontalAlignment="Left" HorizontalContentAlignment="Left"
                                                                Padding="8,4" Margin="0,2" Width="500"
                                                                Command="{Binding DataContext.SelectQuizOptionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Question.IsAnswered}" Value="True">
                                                                            <Setter Property="Background" Value="#EEEEEE"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Margin="0,6,0,0" FontWeight="Bold"
                                                       Visibility="{Binding IsAnswered, Converter={StaticResource NullToVisibilityConverter}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                                <Setter Property="Text" Value="Correto!"/>
                                                                <Setter Property="Foreground" Value="Green"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                                <Setter Property="Text" Value="Incorreto."/>
                                                                <Setter Property="Foreground" Value="#CC0000"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </TabItem>

        <TabItem Header="{DynamicResource Tab_Configuracoes}">
            <StackPanel Margin="20" MaxWidth="550" HorizontalAlignment="Left">
                <TextBlock Text="{DynamicResource Config_Idioma}" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox Margin="0,0,0,15" Width="220" HorizontalAlignment="Left" Padding="5"
                          ItemsSource="{Binding UiLanguageOptions}"
                          SelectedItem="{Binding UiLanguage, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="{DynamicResource Config_ProvedorIA}" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox Margin="0,0,0,15" Width="220" HorizontalAlignment="Left" Padding="5"
                          ItemsSource="{Binding LlmProviderOptions}"
                          SelectedItem="{Binding LlmProvider, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="{DynamicResource Config_ModeloLocal}" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Padding="5" Margin="0,0,5,0"
                             Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="1" Content="{DynamicResource Btn_Procurar}" Command="{Binding BrowseModelCommand}" Padding="10,4"/>
                </Grid>

                <TextBlock Text="Ollama — usado quando o provedor é Ollama" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="URL do servidor" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Padding="5" Text="{Binding OllamaBaseUrl, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Modelo" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Padding="5" Text="{Binding OllamaModel, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="OCR (Tesseract) — texto em imagens e PDFs digitalizados" FontWeight="Bold" Margin="0,0,0,5"/>
                <CheckBox Margin="0,0,0,8" Content="Habilitar OCR" IsChecked="{Binding OcrEnabled, UpdateSourceTrigger=PropertyChanged}"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Pasta tessdata" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Padding="5" Margin="0,0,5,0" Text="{Binding TessDataPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Procurar..." Command="{Binding BrowseTessDataPathCommand}" Padding="10,4"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Idiomas (ex.: por+eng)" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Padding="5" Text="{Binding OcrLanguages, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Embeddings e busca híbrida — melhora a busca semântica (opcional)" FontWeight="Bold" Margin="0,0,0,5"/>
                <CheckBox Margin="0,0,0,8" Content="Habilitar embeddings/busca híbrida" IsChecked="{Binding EmbeddingsEnabled, UpdateSourceTrigger=PropertyChanged}"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Modelo de embeddings (.onnx)" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Padding="5" Margin="0,0,5,0" Text="{Binding EmbeddingModelPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Procurar..." Command="{Binding BrowseEmbeddingModelCommand}" Padding="10,4"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Vocabulário do tokenizer (vocab.txt)" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Padding="5" Margin="0,0,5,0" Text="{Binding EmbeddingTokenizerPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Procurar..." Command="{Binding BrowseEmbeddingTokenizerCommand}" Padding="10,4"/>
                        </Grid>
                    </StackPanel>
                </Grid>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Peso do BM25 na busca híbrida (0-1)" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                    <TextBox Padding="5" Width="100" HorizontalAlignment="Left" Text="{Binding HybridBm25Weight, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <TextBlock Text="Re-ranking (cross-encoder) — refina os resultados da busca híbrida (opcional)" FontWeight="Bold" Margin="0,0,0,5"/>
                <CheckBox Margin="0,0,0,8" Content="Habilitar re-ranking" IsChecked="{Binding RerankingEnabled, UpdateSourceTrigger=PropertyChanged}"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Modelo de re-ranking (.onnx)" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Padding="5" Margin="0,0,5,0" Text="{Binding RerankingModelPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Procurar..." Command="{Binding BrowseRerankingModelCommand}" Padding="10,4"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Vocabulário do tokenizer (vocab.txt)" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Padding="5" Margin="0,0,5,0" Text="{Binding RerankingTokenizerPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Procurar..." Command="{Binding BrowseRerankingTokenizerCommand}" Padding="10,4"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Transcrição de áudio (Whisper) — arquivos .wav 16kHz mono" FontWeight="Bold" Margin="0,0,0,5"/>
                <CheckBox Margin="0,0,0,8" Content="Habilitar transcrição de áudio" IsChecked="{Binding SttEnabled, UpdateSourceTrigger=PropertyChanged}"/>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Modelo Whisper (ggml .bin)" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Padding="5" Margin="0,0,5,0" Text="{Binding WhisperModelPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Procurar..." Command="{Binding BrowseWhisperModelCommand}" Padding="10,4"/>
                    </Grid>
                </StackPanel>

                <TextBlock Text="{DynamicResource Config_PastaIndice}" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Padding="5" Margin="0,0,5,0" Text="{Binding IndexPath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="1" Content="{DynamicResource Btn_Procurar}" Command="{Binding BrowseIndexPathCommand}" Padding="10,4"/>
                </Grid>

                <TextBlock Text="{DynamicResource Config_TopK}" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Padding="5" Margin="0,0,0,15" Width="100" HorizontalAlignment="Left"
                         Text="{Binding TopK, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="{DynamicResource Config_ContextSize}" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Padding="5" Margin="0,0,0,15" Width="100" HorizontalAlignment="Left"
                         Text="{Binding ContextSize, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Indexação paralela / incremental / automática" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Arquivos processados em paralelo na indexação" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                <TextBox Padding="5" Margin="0,0,0,8" Width="100" HorizontalAlignment="Left"
                         Text="{Binding IndexingParallelism, UpdateSourceTrigger=PropertyChanged}"/>
                <CheckBox Margin="0,0,0,8" Content="Indexação incremental (pular arquivos inalterados)"
                          IsChecked="{Binding IncrementalIndexingEnabled, UpdateSourceTrigger=PropertyChanged}"/>
                <CheckBox Margin="0,0,0,8" Content="Reindexar automaticamente ao detectar alterações na pasta"
                          IsChecked="{Binding AutoReindexEnabled, UpdateSourceTrigger=PropertyChanged}"/>
                <CheckBox Margin="0,0,0,15" Content="Fallback automático de LLM (Ollama, com LLamaSharp local como reserva)"
                          IsChecked="{Binding LlmFallbackEnabled, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Backup e restauração do índice" FontWeight="Bold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Content="Fazer backup..." Command="{Binding BackupIndexCommand}" Padding="10,4" Margin="0,0,10,0"/>
                    <Button Content="Restaurar backup..." Command="{Binding RestoreIndexCommand}" Padding="10,4"/>
                </StackPanel>

                <Button Content="{DynamicResource Btn_Salvar}" Command="{Binding SaveConfigCommand}"
                        Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,15"/>

                <TextBlock Text="Integrações com nuvem (Google Drive / OneDrive / Dropbox)" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Crie um app OAuth no Google Cloud Console / Azure AD Portal / App Console do Dropbox e informe o Client ID (App Key) abaixo (veja CloudSync/README.md). Client secret não é necessário (fluxo PKCE)." Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Google Drive Client ID" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Padding="5" Text="{Binding GoogleDriveClientId, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,5,0">
                        <TextBlock Text="OneDrive Client ID" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Padding="5" Text="{Binding OneDriveClientId, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="5,0,0,0">
                        <TextBlock Text="Dropbox App Key" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox Padding="5" Text="{Binding DropboxClientId, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Conectar Google Drive" Command="{Binding ConnectCloudProviderCommand}" CommandParameter="google" Padding="10,4" Margin="0,0,10,0"/>
                    <Button Content="Conectar OneDrive" Command="{Binding ConnectCloudProviderCommand}" CommandParameter="onedrive" Padding="10,4" Margin="0,0,10,0"/>
                    <Button Content="Conectar Dropbox" Command="{Binding ConnectCloudProviderCommand}" CommandParameter="dropbox" Padding="10,4"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="ID/caminho da pasta remota (Google Drive folderId, OneDrive itemId ou caminho do Dropbox, ex.: /Documentos)" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                    <TextBox Padding="5" Text="{Binding CloudRemoteFolderId, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Sincronizar Google Drive" Command="{Binding SyncCloudProviderCommand}" CommandParameter="google" Padding="10,4" Margin="0,0,10,0"/>
                    <Button Content="Sincronizar OneDrive" Command="{Binding SyncCloudProviderCommand}" CommandParameter="onedrive" Padding="10,4" Margin="0,0,10,0"/>
                    <Button Content="Sincronizar Dropbox" Command="{Binding SyncCloudProviderCommand}" CommandParameter="dropbox" Padding="10,4"/>
                </StackPanel>
                <TextBlock Text="{Binding CloudSyncStatus}" Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,15"/>

                <TextBlock Text="Plugins" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Extratores de terceiros carregados de %LOCALAPPDATA%\QuestResume\plugins" Foreground="Gray" FontSize="11" Margin="0,0,0,5"/>
                <ItemsControl ItemsSource="{Binding LoadedPlugins}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="0,0,0,3"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </TabItem>
    </TabControl>
    </DockPanel>
</Window>
