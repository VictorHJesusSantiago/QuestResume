<Window x:Class="QuestResume.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuestResume.Desktop"
        mc:Ignorable="d"
        Title="QuestResume" Height="650" Width="900">
    <TabControl Margin="10">
        <TabItem Header="Perguntas">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Text="{Binding DocumentsFolder, UpdateSourceTrigger=PropertyChanged}"
                             Width="500" Padding="5" VerticalContentAlignment="Center" Margin="0,0,5,0"/>
                    <Button Content="Procurar..." Command="{Binding BrowseFolderCommand}" Padding="10,4" Margin="0,0,5,0"/>
                    <Button Content="Indexar" Command="{Binding IndexCommand}" Padding="10,4"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
                           Margin="0,10,0,0" TextWrapping="Wrap" Foreground="Gray"/>

                <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Padding="5" VerticalContentAlignment="Center" Margin="0,0,5,0"
                             Text="{Binding QuestionText, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="1" Content="Perguntar" Command="{Binding AskCommand}" Padding="10,4"/>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4" Padding="8" CornerRadius="4" Background="#F0F0F0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Role}" FontWeight="Bold" FontSize="11" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding Sources}" FontStyle="Italic" FontSize="11"
                                                   Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </TabItem>

        <TabItem Header="Configurações">
            <StackPanel Margin="20" MaxWidth="550" HorizontalAlignment="Left">
                <TextBlock Text="Modelo de IA local (.gguf)" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Padding="5" Margin="0,0,5,0"
                             Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="1" Content="Procurar..." Command="{Binding BrowseModelCommand}" Padding="10,4"/>
                </Grid>

                <TextBlock Text="Pasta do índice" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Padding="5" Margin="0,0,0,15"
                         Text="{Binding IndexPath, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Trechos por pergunta (Top-K)" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Padding="5" Margin="0,0,0,15" Width="100" HorizontalAlignment="Left"
                         Text="{Binding TopK, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Tamanho do contexto (tokens)" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Padding="5" Margin="0,0,0,15" Width="100" HorizontalAlignment="Left"
                         Text="{Binding ContextSize, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Salvar configurações" Command="{Binding SaveConfigCommand}"
                        Padding="10,4" HorizontalAlignment="Left"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
