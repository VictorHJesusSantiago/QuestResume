<Project>
  <!--
    Publishes QuestResume.Desktop as a self-contained, single-file Windows executable (no .NET
    runtime install required on the target machine). Run with:
      dotnet publish src/QuestResume.Desktop/QuestResume.Desktop.csproj -c Release -p:PublishProfile=win-x64
  -->
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishDir>bin\Release\net8.0-windows\publish\win-x64\</PublishDir>
  </PropertyGroup>
</Project>
